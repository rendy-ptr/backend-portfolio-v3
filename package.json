{
  "name": "backend-portfolio-v3",
  "type": "module",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy --minify",
    "cf-typegen": "wrangler types --env-interface CloudflareBindings",
    "db:generate": "drizzle-kit generate --config drizzle.dev.config.ts",
    "db:migrate:local": "wrangler d1 migrations apply portfolio-v3-db --local",
    "db:migrate:prod": "wrangler d1 migrations apply portfolio-v3-db --remote",
    "db:reset:local": "node -e \"fs.rmSync('.wrangler/state/v3/d1', { recursive: true, force: true })\" && wrangler d1 migrations apply portfolio-v3-db --local",
    "db:studio:local": "drizzle-kit studio --config drizzle.dev.config.ts",
    "db:studio:prod": "drizzle-kit studio --config drizzle.prod.config.ts"
  },
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "dotenv": "^17.3.1",
    "drizzle-orm": "^0.45.1",
    "drizzle-seed": "^0.3.1",
    "hono": "^4.12.8"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260313.1",
    "@types/node": "^25.5.0",
    "better-sqlite3": "^12.8.0",
    "drizzle-kit": "^0.31.10",
    "tsx": "^4.21.0",
    "wrangler": "^4.81.1"
  }
}